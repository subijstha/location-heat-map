<?xml version="1.0" encoding="utf-8" ?>
<!--
    MainPage.xaml
    Primary UI layout containing the map, heat map overlay,
    and control buttons for the location tracking app.
-->
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    xmlns:vm="clr-namespace:LocationHeatMap.ViewModels"
    xmlns:controls="clr-namespace:LocationHeatMap.Controls"
    x:Class="LocationHeatMap.MainPage"
    Title="MainView"
    Shell.NavBarColor="#6A0DAD"
    Shell.TitleColor="White">

    <!-- Bind to ViewModel -->
    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*, Auto, Auto">

        <!-- ═══════════════════════════════════════════════════════════════
             Row 0: Map + Heat Map Overlay stacked together
        ════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0">

            <!-- Base map layer -->
            <maps:Map
                x:Name="MainMap"
                IsShowingUser="True"
                MapType="Street"
                IsScrollEnabled="True"
                IsZoomEnabled="True" />

            <!-- Heat map canvas overlay (transparent background) -->
            <GraphicsView
                x:Name="HeatMapCanvas"
                BackgroundColor="Transparent"
                InputTransparent="True"
                HorizontalOptions="Fill"
                VerticalOptions="Fill" />

        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 1: Control Buttons
        ════════════════════════════════════════════════════════════════ -->
        <HorizontalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Spacing="12"
            Padding="10">

            <!-- Start / Stop Tracking Button -->
            <Button
                Text="{Binding TrackingButtonText}"
                Command="{Binding ToggleTrackingCommand}"
                BackgroundColor="#6A0DAD"
                TextColor="White"
                CornerRadius="8"
                FontAttributes="Bold"
                Padding="16,10" />

            <!-- Refresh Map Button -->
            <Button
                Text="🔄 Refresh"
                Command="{Binding RefreshMapCommand}"
                BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="8"
                Padding="16,10" />

            <!-- Clear Data Button -->
            <Button
                Text="🗑 Clear"
                Command="{Binding ClearDataCommand}"
                BackgroundColor="#F44336"
                TextColor="White"
                CornerRadius="8"
                Padding="16,10" />

        </HorizontalStackLayout>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 2: Status Bar
        ════════════════════════════════════════════════════════════════ -->
        <Frame
            Grid.Row="2"
            BackgroundColor="#1A1A2E"
            Padding="10,6"
            HasShadow="False"
            CornerRadius="0">

            <Label
                Text="{Binding StatusMessage}"
                TextColor="White"
                FontSize="12"
                HorizontalOptions="Center" />

        </Frame>

    </Grid>
</ContentPage>
